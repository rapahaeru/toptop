# App
NODE_ENV=development
API_PORT=3000

# MySQL
DB_HOST=127.0.0.1
DB_NAME=toptop
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_ROOT_PASSWORD=sua_senha_root
DB_PORT=3306

# Timezone do servidor MySQL (opcional)
TZ=America/Sao_Paulo

# Charset
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# CORS (separar múltiplas origens por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://seudominio.com

# JWT — gere valores aleatórios longos (ex: openssl rand -base64 64)
JWT_ACCESS_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_REFRESH_SECRET=troque-por-outro-segredo-longo-e-aleatorio
